<file path="Frontend/src/App.css">
.app-shell {
  min-height: 100vh;
  background: #faf8ff;
  color: #191b23;
}

.top-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 40;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 20px;
  background: rgb(250 248 255 / 80%);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid rgb(25 27 35 / 8%);
}

.brand {
  font-family: 'Manrope', sans-serif;
  font-size: 20px;
  letter-spacing: -0.04em;
  font-weight: 700;
}

.top-links {
  display: flex;
  align-items: center;
  gap: 24px;
}

.top-links a {
  position: relative;
  text-decoration: none;
  color: rgb(25 27 35 / 72%);
  font-size: 13px;
}

.top-links a.active {
  color: #0056d2;
}

.top-links a.active::after {
  content: '';
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  bottom: -8px;
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: #00ad73;
}

.top-tools {
  display: flex;
  align-items: center;
  gap: 6px;
}

.login-link-btn,
.logout-btn {
  border: 1px solid #cfd7ec;
  background: #fff;
  color: #1b2542;
  border-radius: 999px;
  padding: 6px 12px;
  font-size: 12px;
  font-weight: 600;
  text-decoration: none;
  line-height: 1;
  cursor: pointer;
}

.logout-btn:hover,
.login-link-btn:hover {
  border-color: #0056d2;
  color: #0056d2;
}

.account-link-btn {
  border: 0;
  background: transparent;
  padding: 3px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  color: #191b23;
  text-decoration: none;
}

.cart-button {
  position: relative;
}

.cart-dot {
  position: absolute;
  top: 4px;
  right: 4px;
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: #00ad73;
}

.material-symbols-outlined {
  font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
  font-size: 20px;
}

.page-main {
  padding-top: 60px;
}

.hero {
  position: relative;
  overflow: hidden;
}

.hero-editorial {
  min-height: calc(78vh - 60px);
  display: flex;
  align-items: center;
  padding: 18px 20px;
}

.hero-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, rgb(250 248 255 / 45%) 0%, rgb(250 248 255 / 18%) 55%, rgb(250 248 255 / 12%) 100%);
}

.hero-content {
  position: relative;
  z-index: 1;
  max-width: 680px;
}

.edition {
  text-transform: uppercase;
  letter-spacing: 0.24em;
  font-size: 10px;
  color: #0056d2;
  margin-bottom: 14px;
}

.hero-content h1 {
  margin: 0;
  font-family: 'Manrope', sans-serif;
  font-size: clamp(40px, 6.1vw, 72px);
  line-height: 0.9;
  letter-spacing: -0.045em;
  max-width: 720px;
}

.hero-cta-row {
  margin-top: 22px;
  display: flex;
  align-items: center;
  gap: 20px;
}

.hero-sub {
  margin: 0;
  max-width: 250px;
  font-size: 11px;
  line-height: 1.5;
  color: rgb(25 27 35 / 65%);
}

.primary-btn {
  text-decoration: none;
  border: 0;
  border-radius: 4px;
  padding: 12px 18px;
  text-transform: uppercase;
  letter-spacing: 0.11em;
  font-size: 10px;
  font-weight: 700;
  color: #fff;
  background: linear-gradient(135deg, #0040a1 0%, #0056d2 100%);
}

.section {
  padding: 56px 20px;
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16px;
  margin-bottom: 24px;
}

.curated-spheres .section-head,
.curated-spheres .sphere-grid {
  max-width: 1220px;
  margin-left: auto;
  margin-right: auto;
}

.section-head h2 {
  margin: 0;
  font-family: 'Manrope', sans-serif;
  font-size: clamp(28px, 3.2vw, 38px);
  line-height: 1;
  letter-spacing: -0.03em;
}

.section-note {
  margin: 8px 0 0;
  color: rgb(25 27 35 / 60%);
  font-size: 13px;
}

.catalog-link {
  text-decoration: none;
  color: #0056d2;
  text-transform: none;
  font-size: 12px;
  font-weight: 600;
}

.sphere-grid {
  display: grid;
  grid-template-columns: repeat(12, minmax(0, 1fr));
  gap: 12px;
}

.sphere-card {
  position: relative;
  border-radius: 8px;
  overflow: hidden;
  min-height: 250px;
}

.sphere-card img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.7s ease;
}

.sphere-card:hover img {
  transform: scale(1.04);
}

.chatbot-shell {
  position: fixed;
  right: 18px;
  bottom: 18px;
  z-index: 120;
}

.chatbot-trigger {
  border: 0;
  border-radius: 999px;
  background: linear-gradient(135deg, #0056d2 0%, #00ad73 100%);
  color: #fff;
  font-weight: 700;
  font-size: 12px;
  letter-spacing: 0.03em;
  padding: 12px 18px;
  cursor: pointer;
  box-shadow: 0 12px 28px rgb(0 58 143 / 28%);
}

.chatbot-panel {
  width: min(390px, calc(100vw - 24px));
  height: min(620px, calc(100vh - 32px));
  background: #fff;
  border: 1px solid rgb(10 22 64 / 12%);
  border-radius: 14px;
  box-shadow: 0 24px 46px rgb(5 20 53 / 22%);
  display: grid;
  grid-template-rows: auto 1fr auto auto;
  overflow: hidden;
}

.chatbot-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 14px;
  background: linear-gradient(130deg, #edf4ff 0%, #f0fff8 100%);
  border-bottom: 1px solid rgb(10 22 64 / 10%);
}

.chatbot-header h3 {
  margin: 0;
  font-size: 14px;
  line-height: 1;
}

.chatbot-header small {
  color: rgb(25 27 35 / 70%);
  font-size: 11px;
}

.chatbot-header button {
  border: 0;
  background: #d9e7ff;
  color: #13366f;
  width: 26px;
  height: 26px;
  border-radius: 50%;
  cursor: pointer;
  font-weight: 700;
}

.chatbot-messages {
  overflow-y: auto;
  padding: 14px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  background: linear-gradient(180deg, #fff 0%, #f9fbff 100%);
}

.chat-row {
  display: flex;
}

.chat-row p {
  margin: 0;
  max-width: 86%;
  padding: 10px 12px;
  border-radius: 12px;
  font-size: 13px;
  line-height: 1.45;
}

.chat-row.user {
  justify-content: flex-end;
}

.chat-row.user p {
  background: #0056d2;
  color: #fff;
  border-bottom-right-radius: 4px;
}

.chat-row.bot p {
  background: #edf4ff;
  color: #17213d;
  border-bottom-left-radius: 4px;
}

.chatbot-quick-prompts {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  padding: 10px 12px 0;
}

.chatbot-quick-prompts button {
  border: 1px solid #c8dafb;
  background: #f7fbff;
  color: #003f9e;
  font-size: 11px;
  border-radius: 999px;
  padding: 6px 10px;
  cursor: pointer;
}

.chatbot-input {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 8px;
  padding: 12px;
  border-top: 1px solid rgb(10 22 64 / 8%);
}

.chatbot-input input {
  border: 1px solid #d3def3;
  border-radius: 10px;
  padding: 10px;
  font-size: 13px;
}

.chatbot-input button {
  border: 0;
  border-radius: 10px;
  padding: 0 12px;
  background: #0056d2;
  color: #fff;
  font-weight: 600;
  cursor: pointer;
}

.chatbot-input button:disabled {
  opacity: 0.45;
  cursor: not-allowed;
}

@media (max-width: 760px) {
  .chatbot-shell {
    right: 8px;
    bottom: 8px;
  }

  .chatbot-panel {
    width: min(96vw, 430px);
    height: min(74vh, 640px);
  }

  .chatbot-trigger {
    padding: 11px 14px;
    font-size: 11px;
  }
}

.sphere-card-large {
  grid-column: span 8;
  min-height: 258px;
}

.sphere-card-small {
  grid-column: span 4;
  min-height: 258px;
}

.sphere-card-wide {
  grid-column: 2 / span 10;
  min-height: 118px;
}

.sphere-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 18px;
  background: linear-gradient(180deg, rgb(0 0 0 / 5%) 30%, rgb(0 0 0 / 58%) 100%);
}

.sphere-overlay h3 {
  margin: 0;
  color: #fff;
  font-family: 'Manrope', sans-serif;
  font-size: clamp(20px, 2.2vw, 30px);
  line-height: 1;
}

.sphere-overlay p {
  margin: 10px 0 12px;
  color: rgb(255 255 255 / 85%);
  max-width: 300px;
  font-size: 11px;
}

.sphere-overlay span {
  text-transform: uppercase;
  letter-spacing: 0.14em;
  font-size: 9px;
  color: #fff;
}

.sphere-overlay-center {
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, rgb(0 0 0 / 25%) 0%, rgb(0 0 0 / 20%) 100%);
}

.sphere-overlay-center h3 {
  font-size: clamp(22px, 2.4vw, 30px);
}

.sphere-overlay-center button {
  margin-top: 8px;
  border: 0;
  background: #fff;
  color: #191b23;
  border-radius: 999px;
  padding: 6px 14px;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  font-size: 9px;
}

.editorial-arrivals {
  background: #eef0fa;
}

.arrivals-head span {
  text-transform: uppercase;
  letter-spacing: 0.2em;
  font-size: 10px;
  font-weight: 700;
  color: #006c47;
}

.state-line {
  margin: 0 0 16px;
  color: #565d75;
  font-size: 14px;
}

.state-line.error {
  color: #ba1a1a;
}

.arrivals-grid,
.shop-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12px;
}

.product-card,
.shop-card {
  border-radius: 8px;
}

.product-media,
.shop-card-media {
  position: relative;
  aspect-ratio: 3 / 4;
  border-radius: 8px;
  overflow: hidden;
  background: #fff;
}

.product-media img,
.shop-card-media img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.product-badge {
  position: absolute;
  top: 10px;
  left: 10px;
  border-radius: 999px;
  background: #8af5be;
  color: #002113;
  padding: 4px 8px;
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.12em;
}

.product-action {
  position: absolute;
  right: 10px;
  bottom: 10px;
  border: 0;
  width: 30px;
  height: 30px;
  border-radius: 999px;
  background: rgb(255 255 255 / 90%);
  font-size: 20px;
  line-height: 1;
  cursor: pointer;
}

.product-brand {
  margin: 10px 0 5px;
  font-size: 9px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: rgb(25 27 35 / 54%);
}

.product-card h3 {
  margin: 0;
  font-family: 'Manrope', sans-serif;
  font-size: 16px;
  letter-spacing: -0.01em;
}

.product-price {
  margin: 5px 0 0;
  color: #0040a1;
  font-size: 14px;
  font-weight: 500;
}

.journal-highlight {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 30px;
  align-items: center;
}

.journal-media {
  position: relative;
}

.journal-media img {
  width: 100%;
  border-radius: 12px;
  height: 470px;
  object-fit: cover;
  box-shadow: 0 20px 50px rgb(8 10 16 / 25%);
}

.journal-quote {
  position: absolute;
  right: 18px;
  bottom: 18px;
  max-width: 270px;
  background: #fff;
  border-radius: 3px;
  padding: 16px;
}

.journal-quote p {
  margin: 0 0 8px;
  font-size: 12px;
  line-height: 1.6;
  font-style: italic;
}

.journal-quote span {
  text-transform: uppercase;
  letter-spacing: 0.14em;
  font-size: 9px;
  color: #4d5369;
}

.journal-copy > span {
  text-transform: uppercase;
  letter-spacing: 0.28em;
  font-size: 10px;
  color: #006c47;
}

.journal-copy h2 {
  margin: 10px 0 16px;
  font-family: 'Manrope', sans-serif;
  font-size: clamp(32px, 4vw, 48px);
  line-height: 0.98;
  letter-spacing: -0.03em;
}

.journal-copy > p {
  margin: 0 0 18px;
  color: #424654;
  line-height: 1.7;
}

.journal-copy ul {
  list-style: none;
  padding: 0;
  margin: 0;
}

.journal-copy li {
  display: flex;
  gap: 14px;
  border-bottom: 1px solid rgb(115 119 133 / 25%);
  padding: 12px 0;
}

.journal-copy li strong {
  color: #737785;
  font-family: 'Manrope', sans-serif;
  font-size: 28px;
}

.journal-copy li h4 {
  margin: 3px 0 4px;
  font-size: 20px;
  font-family: 'Manrope', sans-serif;
}

.journal-copy li p {
  margin: 0;
  font-size: 13px;
  color: #555b73;
}

.journal-copy > a {
  display: inline-block;
  margin-top: 18px;
  text-decoration: none;
  text-transform: uppercase;
  letter-spacing: 0.16em;
  font-size: 11px;
  color: #0040a1;
  border-bottom: 2px solid #0040a1;
  padding-bottom: 4px;
}

.registry-strip {
  position: relative;
  overflow: hidden;
  padding: 50px 20px;
  background: #2e3038;
}

.registry-word {
  position: absolute;
  top: -4px;
  right: 18px;
  color: rgb(240 240 251 / 12%);
  font-family: 'Manrope', sans-serif;
  font-size: clamp(90px, 16vw, 220px);
  line-height: 0.9;
  font-weight: 800;
  pointer-events: none;
}

.registry-content {
  position: relative;
  z-index: 1;
  max-width: 700px;
}

.registry-content h2 {
  margin: 0 0 8px;
  color: #f0f0fb;
  font-family: 'Manrope', sans-serif;
  font-size: clamp(30px, 3.4vw, 42px);
}

.registry-content p {
  margin: 0 0 20px;
  color: rgb(240 240 251 / 74%);
  max-width: 530px;
}

.registry-form {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}

.registry-form input {
  border: 1px solid rgb(240 240 251 / 20%);
  background: rgb(240 240 251 / 8%);
  color: #f0f0fb;
  min-width: 280px;
  flex: 1;
  padding: 12px;
  outline: none;
}

.registry-form input::placeholder {
  color: rgb(240 240 251 / 50%);
}

.registry-form button {
  border: 0;
  border-radius: 0;
  background: linear-gradient(135deg, #0040a1 0%, #0056d2 100%);
  color: #fff;
  text-transform: uppercase;
  letter-spacing: 0.16em;
  font-size: 10px;
  font-weight: 700;
  padding: 12px 18px;
}

.site-footer {
  background: #f2f3fe;
  border-top: 1px solid #e0e2ed;
  padding: 30px 20px;
  display: grid;
  grid-template-columns: 1.4fr 1fr 1fr 1fr;
  gap: 18px;
}

.footer-column h4,
.footer-column h5 {
  margin: 0 0 12px;
  font-family: 'Manrope', sans-serif;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  font-size: 12px;
}

.footer-brand h4 {
  text-transform: none;
  letter-spacing: -0.01em;
  font-size: 21px;
}

.footer-column p,
.footer-column a {
  display: block;
  margin: 0 0 8px;
  color: rgb(25 27 35 / 63%);
  text-decoration: none;
  font-size: 12px;
}

.footer-icons {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 10px;
}

.copyright {
  text-transform: uppercase;
  letter-spacing: 0.13em;
  font-size: 10px;
}

.shop-wrap {
  padding: 16px 20px 64px;
}

.shop-header h1 {
  margin: 0;
  font-size: clamp(32px, 4.7vw, 50px);
  font-family: 'Manrope', sans-serif;
  letter-spacing: -0.03em;
}

.shop-header p {
  margin-top: 8px;
  max-width: 760px;
  color: #565f79;
}

.shop-content {
  margin-top: 24px;
  display: grid;
  grid-template-columns: 260px 1fr;
  gap: 24px;
  align-items: start;
}

.shop-grid-area {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.shop-sidebar {
  background: #f5f6ff;
  border-radius: 10px;
  border: 1px solid #e1e5f2;
  padding: 18px;
  height: fit-content;
}

.filter-block {
  margin-bottom: 26px;
}

.filter-block h3 {
  margin: 0 0 12px;
  font-size: 13px;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: #1f4aa2;
}

.filter-block label {
  display: flex;
  align-items: center;
  gap: 9px;
  font-size: 13px;
  margin-bottom: 8px;
}

.filter-block input[type='range'] {
  width: 100%;
  accent-color: #1f55c6;
}

.range-labels {
  display: flex;
  justify-content: space-between;
  font-size: 12px;
  color: #6d748f;
}

.shop-toolbar {
  display: grid;
  grid-template-columns: 1fr 240px 180px;
  gap: 12px;
  margin-bottom: 16px;
  align-items: center;
}

.shop-search,
.shop-toolbar select {
  border: 1px solid #d0d6e8;
  background: #fff;
  border-radius: 8px;
  padding: 8px 10px;
}

.shop-card-meta {
  margin-top: 10px;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 10px;
}

.shop-card-meta h4 {
  margin: 0;
  font-family: 'Manrope', sans-serif;
}

.shop-card-meta span {
  color: #2753ad;
  font-weight: 700;
}

.shop-card p {
  color: #67708d;
  margin: 8px 0 0;
  font-size: 13px;
  line-height: 1.4;
}

.shop-grid {
  align-items: start;
}

.shop-card {
  display: flex;
  flex-direction: column;
  min-width: 0;
  background: #fff;
  border: 1px solid #dfe5f5;
  border-radius: 10px;
  padding: 8px;
}

.shop-card-media {
  aspect-ratio: 4 / 3;
}

.shop-card-meta h4 {
  font-size: 20px;
  line-height: 1.35;
  overflow-wrap: anywhere;
}

.pagination {
  display: flex;
  justify-content: center;
  gap: 8px;
  margin-top: 20px;
  margin-bottom: 8px;
  flex-wrap: wrap;
}

.pagination button {
  border: 1px solid #c9cfe2;
  width: 34px;
  height: 34px;
  border-radius: 999px;
  background: #fff;
}

.pagination button.active {
  background: #1f52b2;
  color: #fff;
  border-color: #1f52b2;
}

.content-page {
  max-width: 880px;
  margin: 20px auto 70px;
  background: #f7f8ff;
  border: 1px solid #e1e5f3;
  border-radius: 12px;
  padding: 30px;
}

.content-page .kicker {
  text-transform: uppercase;
  letter-spacing: 0.14em;
  font-size: 12px;
  color: #1e50ad;
}

.content-page h1 {
  margin: 8px 0 12px;
  font-family: 'Manrope', sans-serif;
  font-size: clamp(28px, 4.2vw, 44px);
  line-height: 1;
}

.content-page p {
  color: #57607c;
  line-height: 1.8;
}

.auth-shell {
  min-height: 100vh;
  display: grid;
  grid-template-columns: 1fr 1fr;
  background: #faf8ff;
}

.auth-shell-user .auth-showcase-overlay {
  background: linear-gradient(180deg, rgb(0 49 89 / 12%) 10%, rgb(0 31 56 / 68%) 100%);
}

.auth-shell-admin .auth-showcase-overlay {
  background: linear-gradient(180deg, rgb(16 22 37 / 8%) 10%, rgb(16 22 37 / 78%) 100%);
}

.auth-showcase {
  position: relative;
  overflow: hidden;
  background: #191b23;
}

.auth-showcase img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0.8;
}

.auth-showcase-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgb(25 27 35 / 10%) 8%, rgb(25 27 35 / 65%) 100%);
}

.auth-showcase-content {
  position: relative;
  z-index: 1;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 46px 48px 36px;
}

.auth-showcase-content h1 {
  margin: 0;
  color: #fff;
  font-family: 'Manrope', sans-serif;
  font-size: 36px;
  letter-spacing: -0.02em;
}

.auth-showcase-content p {
  margin: 0;
  color: #fff;
  font-family: 'Manrope', sans-serif;
  font-size: clamp(34px, 4.5vw, 56px);
  line-height: 0.98;
  letter-spacing: -0.03em;
}

.auth-showcase-content p strong {
  font-weight: 800;
}

.auth-showcase-content span {
  margin-top: 18px;
  display: inline-block;
  max-width: 520px;
  color: rgb(255 255 255 / 76%);
  font-size: 20px;
  line-height: 1.4;
}

.auth-showcase-stats {
  display: flex;
  gap: 36px;
}

.auth-showcase-stats strong {
  display: block;
  color: #fff;
  font-size: 30px;
  font-family: 'Manrope', sans-serif;
}

.auth-showcase-stats small {
  text-transform: uppercase;
  letter-spacing: 0.16em;
  font-size: 10px;
  color: rgb(255 255 255 / 56%);
}

.auth-form-pane {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24px;
}

.auth-form-wrap {
  width: min(460px, 100%);
}

.auth-scope-switch {
  margin-bottom: 28px;
  border: 1px solid #dde0ec;
  padding: 4px;
  border-radius: 999px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4px;
}

.auth-scope-switch a {
  text-decoration: none;
  color: #4a5063;
  font-size: 13px;
  border-radius: 999px;
  text-align: center;
  padding: 8px 10px;
  font-weight: 600;
}

.auth-scope-switch a.active {
  background: linear-gradient(135deg, #0040a1 0%, #0056d2 100%);
  color: #fff;
}

.auth-form-wrap header h2 {
  margin: 0;
  font-family: 'Manrope', sans-serif;
  font-size: clamp(34px, 4vw, 42px);
  letter-spacing: -0.03em;
}

.auth-form-wrap header p {
  margin: 8px 0 0;
  color: #59617b;
  line-height: 1.5;
}

.auth-social-grid {
  margin-top: 28px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}

.auth-social-grid button {
  border: 1px solid #dde0ec;
  background: #fff;
  border-radius: 10px;
  padding: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  cursor: pointer;
}

.auth-divider {
  margin: 24px 0;
  position: relative;
  text-align: center;
}

.auth-divider-top {
  margin-top: 16px;
}

.auth-divider::before {
  content: '';
  position: absolute;
