  color: #6f7894;
  font-size: 10px;
  font-weight: 700;
}

.bo-kpi-card strong {
  display: block;
  font-family: 'Manrope', sans-serif;
  font-size: clamp(25px, 2.2vw, 34px);
  letter-spacing: -0.02em;
}

.bo-kpi-card-dark {
  color: #fff;
  background: linear-gradient(140deg, #1f2537 0%, #161b2b 100%);
  border-color: #20283d;
}

.bo-kpi-card-dark p {
  color: rgb(255 255 255 / 70%);
}

.bo-kpi-icon {
  width: 44px;
  height: 44px;
  border-radius: 12px;
  display: grid;
  place-items: center;
}

.bo-kpi-icon span {
  font-size: 22px;
}

.bo-kpi-icon.icon-blue {
  color: #1652b8;
  background: #e2ecff;
}

.bo-kpi-icon.icon-green {
  color: #0d8558;
  background: #ddf4ea;
}

.bo-kpi-icon.icon-orange {
  color: #ba5500;
  background: #ffe7d7;
}

.bo-kpi-icon.icon-teal {
  color: #0a6f66;
  background: #d8f3f0;
}

.bo-kpi-icon.icon-red {
  color: #b42020;
  background: #ffdede;
}

.bo-kpi-icon.icon-soft {
  color: #fff;
  background: rgb(255 255 255 / 10%);
}

.bo-table-wrap,
.bo-panel {
  background: #fff;
  border: 1px solid #dee4f3;
  border-radius: 16px;
  overflow: hidden;
}

.bo-table-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 8px;
  padding: 14px 16px;
  background: #f3f6ff;
  border-bottom: 1px solid #e1e6f3;
}

.bo-table-head h3 {
  margin: 0;
  font-family: 'Manrope', sans-serif;
  font-size: 18px;
}

.bo-table-head span {
  color: #5f6a88;
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 0.11em;
  font-weight: 700;
}

.bo-scroll {
  overflow-x: auto;
}

.bo-table {
  width: 100%;
  border-collapse: collapse;
  min-width: 760px;
}

.bo-table th,
.bo-table td {
  padding: 11px 12px;
  border-bottom: 1px solid #e8ecf7;
  font-size: 13px;
  text-align: left;
  vertical-align: middle;
}

.bo-table th {
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: #647090;
}

.bo-table td button {
  border: 1px solid #ced7eb;
  background: #fff;
  color: #23418f;
  border-radius: 8px;
  padding: 5px 10px;
  font-weight: 700;
  font-size: 12px;
  cursor: pointer;
}

.bo-table td input,
.bo-table td select {
  border: 1px solid #cdd5ea;
  border-radius: 8px;
  background: #fff;
  padding: 7px 8px;
  min-width: 110px;
}

.bo-product-name strong {
  display: block;
}

.bo-product-name small {
  color: #6b7490;
}

.bo-stock-wrap {
  display: flex;
  align-items: center;
  gap: 8px;
}

.bo-stock-track {
  width: 96px;
  height: 6px;
  border-radius: 999px;
  background: #e5e8f4;
  overflow: hidden;
}

.bo-stock-fill {
  display: block;
  height: 100%;
}

.bo-stock-fill.ok {
  background: #158356;
}

.bo-stock-fill.warning {
  background: #cf8b00;
}

.bo-stock-fill.danger {
  background: #b02020;
}

.bo-inline-actions {
  display: flex;
  align-items: center;
  gap: 8px;
}

.bo-badge {
  display: inline-flex;
  align-items: center;
  border-radius: 999px;
  padding: 4px 9px;
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.11em;
  font-weight: 700;
}

.bo-badge-pending {
  background: #ffe2cd;
  color: #944300;
}

.bo-badge-processing {
  background: #efe1ff;
  color: #69219f;
}

.bo-badge-shipping {
  background: #dfe9ff;
  color: #184bb4;
}

.bo-badge-completed {
  background: #dbf5e7;
  color: #0f7a4f;
}

.bo-badge-cancelled {
  background: #ffdfdf;
  color: #9e1a1a;
}

.bo-admin-grid,
.bo-split-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12px;
}

.bo-panel {
  padding: 14px;
}

.bo-panel h3 {
  margin: 2px 0 12px;
  font-family: 'Manrope', sans-serif;
  font-size: 20px;
}

.bo-form {
  display: grid;
  gap: 9px;
}

.bo-form-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.bo-form input,
.bo-form select,
.bo-form textarea {
  border: 1px solid #d0d7ec;
  border-radius: 10px;
  padding: 9px 10px;
  background: #fdfdff;
  width: 100%;
}

.bo-check-row {
  display: flex;
  align-items: center;
  gap: 8px;
}

.bo-check-row input {
  width: auto;
}

.bo-metrics-stack {
  padding: 16px;
  display: grid;
  gap: 9px;
}

.bo-mini-stat {
  border: 1px solid #e1e6f4;
  border-radius: 12px;
  padding: 10px 12px;
  background: #f8f9ff;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.bo-mini-stat span {
  color: #617092;
  font-size: 12px;
}

.bo-mini-stat strong {
  font-family: 'Manrope', sans-serif;
  font-size: 22px;
}

@media (max-width: 1200px) {
  .bo-shell {
    grid-template-columns: 90px 1fr;
  }

  .bo-brand p,
  .bo-nav a span:last-child,
  .bo-user-card div {
    display: none;
  }

  .bo-brand h1 {
    font-size: 18px;
  }

  .bo-nav a {
    justify-content: center;
  }

  .bo-user-card {
    justify-content: center;
  }

  .bo-user-card img {
    width: 36px;
    height: 36px;
  }
}

@media (max-width: 980px) {
  .bo-main {
    padding: 14px;
  }

  .bo-header {
    position: static;
    flex-direction: column;
    align-items: stretch;
  }

  .bo-header-actions {
    flex-wrap: wrap;
  }

  .bo-search {
    width: 100%;
  }

  .bo-kpi-grid,
  .bo-kpi-grid-staff,
  .bo-admin-grid,
  .bo-split-grid,
  .bo-form-grid {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 700px) {
  .bo-shell {
    grid-template-columns: 1fr;
  }

  .bo-sidebar {
    position: static;
    height: auto;
    border-right: 0;
    border-bottom: 1px solid #dae1f2;
    padding: 10px;
  }

  .bo-brand p,
  .bo-nav a span:last-child,
  .bo-user-card div {
    display: block;
  }

  .bo-nav {
    flex-direction: row;
    flex-wrap: wrap;
  }

  .bo-nav a {
    flex: 1 1 120px;
    justify-content: center;
  }

  .bo-user-card {
    justify-content: flex-start;
  }
}
